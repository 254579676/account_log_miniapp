/**app.wxss**/
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  background: linear-gradient(to bottom, #2E7D32, #E8F5E9);
  background-attachment: fixed;
  box-sizing: border-box;
}

.container {
  padding: 12rpx;
  overflow: auto;
}
/* 隐藏滚动条但保持滚动功能 */
::-webkit-scrollbar {
  display: none;
}
/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
  padding: 30rpx;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #212121;
}

.subtitle {
  font-size: 32rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 20rpx;
}

/* 按钮样式 */
.btn {
  padding: 24rpx 36rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary {
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  color: #fff;
  border: none;
}

.btn-outline {
  border: 2rpx solid #4CAF50;
  color: #4CAF50;
  background-color: transparent;
}

/* 文本颜色 */
.text-primary {
  color: #4CAF50;
}

.text-danger {
  color: #F44336;
}

.text-muted {
  color: #9E9E9E;
}

.text-success {
  color: #4CAF50;
}

.text-warning {
  color: #FF9800;
}

.text-info {
  color: #2196F3;
}

/* 图标样式 */
.icon {
  width: 48rpx;
  height: 48rpx;
  vertical-align: middle;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: #eee;
  margin: 24rpx 0;
}

/* 弹性布局 */
.flex {
  display: flex;
}

.flex-between {
  justify-content: space-between;
}

.flex-center {
  align-items: center;
}

.flex-column {
  flex-direction: column;
}

/* 边距 */
.mt-10 {
  margin-top: 20rpx;
}

.mb-10 {
  margin-bottom: 20rpx;
}

.ml-10 {
  margin-left: 20rpx;
}

.mr-10 {
  margin-right: 20rpx;
}

.mt-20 {
  margin-top: 40rpx;
}

.mb-20 {
  margin-bottom: 40rpx;
}

.ml-20 {
  margin-left: 40rpx;
}

.mr-20 {
  margin-right: 40rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.tag-expense {
  background-color: #ffebee;
  color: #F44336;
}

.tag-income {
  background-color: #e8f5e9;
  color: #4CAF50;
}

/* 表单样式 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 列表样式 */
.list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.list-item {
  padding: 30rpx;
  border-bottom: 2rpx solid #eee;
}

.list-item:last-child {
  border-bottom: none;
}

/* 头像样式 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

/* 徽章样式 */
.badge {
  display: inline-block;
  min-width: 24rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  text-align: center;
  background-color: #F44336;
  color: #fff;
  border-radius: 18rpx;
}