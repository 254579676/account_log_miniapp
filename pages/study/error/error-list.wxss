.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 0 20rpx 40rpx;
}

/* 顶部信息 */
.header-info {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.student-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.child-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #ecf0f1;
  flex-shrink: 0;
}

.student-details {
  flex: 1;
  min-width: 0;
}

.student-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.student-meta {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.class-info {
  font-size: 24rpx;
  color: #ffffff;
  background: #3498db;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.school-info {
  font-size: 24rpx;
  color: #ffffff;
  background: #27ae60;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

/* 功能按钮区域 */
.function-buttons {
  display: flex;
  gap: 15rpx;
  margin-top: 20rpx;
  justify-content: flex-end;
}

.analysis-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(102, 126, 234, 0.15);
}

.analysis-btn:active {
  transform: scale(0.95);
}

.add-error-btn {
  background: linear-gradient(135deg, #27ae60, #229954);
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(39, 174, 96, 0.15);
}

.add-error-btn:active {
  transform: scale(0.95);
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

/* 筛选条件 */
.filter-section {
  background: white;
  padding: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.filter-label {
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
  flex-shrink: 0;
  width: 60rpx;
  text-align: right;
}

picker {
  flex: 1;
  display: block;
}

.filter-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background: #f8f9fa;
  border: 1rpx solid #e9ecef;
  border-radius: 6rpx;
  font-size: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.filter-text {
  color: #333;
  flex: 1;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-arrow {
  color: #999;
  font-size: 18rpx;
  margin-left: 6rpx;
  flex-shrink: 0;
}

/* 日期选择弹窗 */
.date-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.date-picker-content {
  background: white;
  border-radius: 16rpx;
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.date-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.date-picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.date-picker-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
}

.quick-select {
  margin-bottom: 30rpx;
}

.quick-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.quick-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.quick-option {
  padding: 20rpx;
  text-align: center;
  border: 1rpx solid #e9ecef;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s ease;
}

.quick-option.active {
  background: #2196F3;
  color: white;
  border-color: #2196F3;
}

.quick-option:active {
  transform: scale(0.98);
}

.custom-date {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 30rpx;
}

.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.date-label {
  font-size: 26rpx;
  color: #333;
  width: 120rpx;
}

.date-picker {
  flex: 1;
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border: 1rpx solid #e9ecef;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
}

.date-picker-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.confirm-btn {
  flex: 1;
  height: 70rpx;
  background: #2196F3;
  color: white;
  border: none;
  border-radius: 35rpx;
  font-size: 28rpx;
}

.confirm-btn::after {
  border: none;
}

/* 学科错题统计 */
.subject-stats {
  background: white;
  border-radius: 12rpx;
  padding: 16rpx 8rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  min-height: 220rpx; /* 增加整体高度 */
  overflow: hidden; /* 防止内容溢出 */
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  text-align: center;
}

.chart-container {
  max-height: 180rpx; /* 增加图表容器高度 */
  overflow: hidden; /* 防止图表溢出 */
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 180rpx; /* 增加图表高度 */
  padding: 0 8rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  max-width: 55rpx;
  height: 180rpx; /* 与chart-bars保持一致 */
}

.bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 6rpx;
  max-height: 140rpx; /* 增加柱状图区域最大高度 */
}

.bar-value {
  font-size: 20rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.bar {
  width: 32rpx;
  height: 100rpx; /* 增加柱状图高度 */
  background: #f5f5f5;
  border-radius: 16rpx 16rpx 0 0;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.bar-fill {
  width: 100%;
  border-radius: 16rpx 16rpx 0 0;
  transition: height 0.6s ease;
  position: absolute;
  bottom: 0;
  max-height: 100rpx; /* 增加填充高度限制 */
}

.bar-label {
  font-size: 18rpx;
  color: #666;
  text-align: center;
  margin-top: 4rpx;
  word-break: break-all;
}

/* 错题列表容器（固定高度） */
.error-list-container {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  /* 固定高度，实现内部滚动 */
  height: 780rpx; /* 减少20rpx来给统计图表更多空间 */
}

/* 错题列表滚动区域 */
.error-list-scroll {
  height: 100%;
  background: white;
}

/* 错题列表 */
.error-list {
  background: white;
}

.error-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s ease;
}

.error-item:last-child {
  border-bottom: none;
}

.error-item:active {
  background-color: #f8f9fa;
}

/* 头部信息 */
.error-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.subject-tag {
  font-size: 26rpx;
  font-weight: 600;
  color: #1976d2;
  background: #e3f2fd;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #bbdefb;
}

.type-tag {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e0e0e0;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.date-text {
  font-size: 24rpx;
  color: #999;
}

.edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #f5f5f5;
  transition: all 0.2s ease;
}

.edit-btn:active {
  background: #e0e0e0;
  transform: scale(0.9);
}

.edit-icon {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

/* 内容区域 */
.content-section, .solution-section {
  margin-bottom: 10rpx;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
  border-left: 4rpx solid #2196f3;
}solution-section

.solution-section {
  border-left-color: #4caf50;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.content-text, .solution-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  word-break: break-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  cursor: pointer;
  transition: color 0.2s ease;
}

.content-text:active, .solution-text:active {
  color: #1976d2;
}

/* 底部区域 */
.footer-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
}

.tag-item {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.difficulty-tag {
  border: 1rpx solid;
}

.difficulty-easy{
  background: #e8f5e8;
  color: #2e7d32;
  border-color: #a5d6a7;
}

.difficulty-middle {
  background: #fff3e0;
  color: #f57c00;
  border-color: #ffcc02;
}

.difficulty-hard {
  background: #ffebee;
  color: #c62828;
  border-color: #ef9a9a;
}

.mastery-tag {
  border: 1rpx solid;
}

.mastery-not_mastered {
  background: #ffebee;
  color: #c62828;
  border-color: #ef9a9a;
}

.mastery-partially_mastered {
  background: #fff3e0;
  color: #f57c00;
  border-color: #ffcc02;
}

.mastery-mastered {
  background: #e8f5e8;
  color: #2e7d32;
  border-color: #a5d6a7;
}

.reason-tag {
  background: #f3e5f5;
  color: #7b1fa2;
  border: 1rpx solid #ce93d8;
}

/* 图片预览 */
.image-preview {
  display: flex;
  align-items: center;
}

.image-btn {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 1rpx solid #e0e0e0;
  transition: all 0.2s ease;
}

.image-btn:active {
  background: #e0e0e0;
}

.image-icon {
  margin-right: 6rpx;
  font-size: 20rpx;
}

.image-count {
  font-size: 24rpx;
}

/* 空状态 */
.empty-state {
  background: white;
  border-radius: 16rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.empty-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
  display: block;
}

.add-first-btn {
  background: #4CAF50;
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  margin: 0 auto;
}

/* 加载状态 */
.loading-state {
  background: white;
  border-radius: 16rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 加载更多样式 */
.load-more-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.load-more-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.load-more-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 6rpx rgba(102, 126, 234, 0.2);
}

.load-more-text {
  font-size: 28rpx;
  color: #666;
  margin: 0;
}

.no-more-text {
  font-size: 28rpx;
  color: #999;
  margin: 0;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 16rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
}

.edit-options-modal {
  width: 70%;
  max-width: 500rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.close-btn {
  font-size: 36rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.modal-body {
  padding: 0;
}

.edit-option-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f8f8f8;
  transition: background-color 0.2s ease;
}

.edit-option-item:last-child {
  border-bottom: none;
}

.edit-option-item:active {
  background: #f8f9fa;
}

.option-icon {
  font-size: 32rpx;
  margin-right: 24rpx;
  width: 40rpx;
  text-align: center;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.option-arrow {
  font-size: 24rpx;
  color: #ccc;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn {
  width: 100%;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.cancel-btn:active {
  background: #e0e0e0;
}

/* 时间筛选样式（与作业统计页面保持一致） */
.period-selector {
  margin-top: 12rpx;
}

.period-tabs {
  display: flex;
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 4rpx;
}

.period-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 6rpx;
  font-size: 22rpx;
  color: #666;
  border-radius: 6rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.period-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

/* 自定义时间选择器弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  width: 90%;
  max-width: 650rpx;
  max-height: 80vh;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 40rpx 30rpx;
  border-bottom: 1rpx solid #f8f9fa;
  color: white;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-content .close-btn {
  font-size: 36rpx;
  color: rgba(221, 13, 13, 0.8);
  padding: 10rpx;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}