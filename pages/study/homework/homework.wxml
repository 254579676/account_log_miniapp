<view class="container">
  <!-- 顶部信息 -->
  <view class="header-info">
    <!-- 第一行：学生信息 -->
    <view class="student-info">
      <image class="child-avatar" src="{{currentChild.avatar_url || '/assets/icons/child.png'}}" />
      <view class="student-details">
        <text class="student-name">{{currentChild.name}}</text>
        <view class="student-meta">
          <text class="class-info">{{currentChild.grade}} {{currentChild.class}}</text>
          <text class="school-info">{{currentChild.school}}</text>
        </view>
      </view>
    </view>
    
    <!-- 第二行：功能按钮 -->
    <view class="function-buttons">
      <button class="stats-btn" bindtap="onOpenStats">
        <text class="btn-icon">📊</text>
        统计
      </button>
      <button class="add-btn" bindtap="onAddHomework">
        <text class="btn-icon">+</text>
        添加作业
      </button>
    </view>
  </view>

  <!-- 作业统计 -->
  <view class="stats-card">
    <view class="stats-title">{{statsTitle}}</view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-number">{{homeworkStats.total}}</text>
        <text class="stat-label">总作业</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{homeworkStats.completed}}</text>
        <text class="stat-label">已完成</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{homeworkStats.pending}}</text>
        <text class="stat-label">待完成</text>
      </view>
    </view>
  </view>

  <!-- 筛选条件 -->
  <view class="filter-section">
    <view class="filter-row">
      <!-- 年级选择 -->
      <view class="filter-item">
        <text class="filter-label">年级:</text>
        <picker mode="selector" range="{{gradeOptions}}" range-key="name" bindchange="onGradeChange">
          <view class="filter-picker">
            <text class="filter-text">{{selectedGrade.name || '请选择'}}</text>
            <text class="filter-arrow">▼</text>
          </view>
        </picker>
      </view>
      
      <!-- 学科选择 -->
      <view class="filter-item">
        <text class="filter-label">学科:</text>
        <picker mode="selector" range="{{subjectOptions}}" range-key="name" bindchange="onFilterSubjectChange">
          <view class="filter-picker">
            <text class="filter-text">{{selectedSubject.name || '全部'}}</text>
            <text class="filter-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>
    
    <!-- 时间筛选（与错题列表页面保持一致） -->
    <view class="period-selector">
      <view class="period-tabs">
        <view 
          class="period-tab {{selectedPeriod === '今日' ? 'active' : ''}}" 
          bindtap="onQuickPeriodSelect" 
          data-period="今日"
        >
          今日
        </view>
        <view 
          class="period-tab {{selectedPeriod === '本周' ? 'active' : ''}}" 
          bindtap="onQuickPeriodSelect" 
          data-period="本周"
        >
          本周
        </view>
        <view 
          class="period-tab {{selectedPeriod === '本月' ? 'active' : ''}}" 
          bindtap="onQuickPeriodSelect" 
          data-period="本月"
        >
          本月
        </view>
        <view 
          class="period-tab {{selectedPeriod === '自定义' ? 'active' : ''}}" 
          bindtap="onShowCustomDatePicker"
          data-period="自定义"
        >
          自定义
        </view>
      </view>
    </view>
  </view>

  <!-- 作业列表 -->
  <view class="homework-list">
    <view class="list-header">
      <text class="title">作业列表</text>
      <text class="count">{{homeworkList.length}}项</text>
    </view>
    
    <!-- 固定高度滚动容器 -->
    <scroll-view class="homework-scroll" scroll-y="true" bindscrolltolower="onReachBottom">
      <view class="homework-item" wx:for="{{homeworkList}}" wx:key="id" bindtap="onHomeworkDetail" data-id="{{item.id}}" data-subject="{{item.subject_id}}">
        <!-- 第一行：科目、作业类型、完成状态 -->
        <view class="item-row first-row">
          <view class="left-info">
            <text class="subject-name">{{item.subject_name}}</text>
            <text class="homework-type">{{item.homework_type}}</text>
          </view>
          <text class="completion-status {{item.status === '已完成' ? 'completed' : 'pending'}}">{{item.status || '待完成'}}</text>
        </view>

        <!-- 第二行：作业标题、作业描述 -->
        <view class="item-row second-row">
          <view class="content-info">
            <text class="homework-title">{{item.title}}</text>
            <text class="homework-desc" wx:if="{{item.description}}">{{item.description}}</text>
          </view>
        </view>

        <!-- 第三行：作业日期、预计时间、实际时间 -->
        <view class="item-row third-row">
          <text class="homework-date" wx:if="{{item.due_date}}">📅 {{item.due_date}}</text>
          <view class="time-info">
            <text class="estimated-time">预计{{item.estimated_time}}分钟</text>
            <text class="actual-time" wx:if="{{item.status === '已完成' && item.actual_time}}">实际{{item.actual_time}}分钟</text>
          </view>
        </view>
      </view>
      
      <!-- 加载更多提示 -->
      <view class="load-more-container" wx:if="{{pagination.hasMore && homeworkList.length > 0}}">
        <view class="loading-more" wx:if="{{isLoading}}">
          <text class="loading-text">加载中...</text>
        </view>
        <view class="load-more-tip" wx:else>
          <text class="load-more-text">上拉加载更多</text>
        </view>
      </view>
      
      <!-- 没有更多数据提示 -->
      <view class="no-more-container" wx:if="{{!pagination.hasMore && homeworkList.length > 0}}">
        <text class="no-more-text">没有更多数据了</text>
      </view>
    </scroll-view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{homeworkList.length === 0}}">
    <image class="empty-icon" src="/assets/icons/empty-homework.png" />
    <text class="empty-text">今天还没有作业记录</text>
    <text class="empty-desc">点击上方按钮添加作业</text>
  </view>

  <!-- 添加作业弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="onCancel">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header" catchtap="stopPropagation">
        <text class="modal-title">添加作业</text>
        <text class="close-btn" bindtap="onCancel">×</text>
      </view>
      
      <view class="modal-body" catchtap="stopPropagation">
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">科目 *</text>
            <picker mode="selector" range="{{subjects}}" bindchange="onSubjectChange">
              <view class="picker">
                {{formData.subject_id ? subjectNameMap[formData.subject_id] || '未知科目' : '请选择科目'}}
                <text class="picker-arrow">></text>
              </view>
            </picker>
          </view>
          
          <view class="form-item half">
            <text class="form-label">作业类型</text>
            <picker mode="selector" range="{{homeworkTypes}}" bindchange="onHomeworkTypeChange">
              <view class="picker">
                {{formData.homework_type || '请选择类型'}}
                <text class="picker-arrow">></text>
              </view>
            </picker>
          </view>
        </view>

        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">作业日期 *</text>
            <picker mode="date" bindchange="onHomeworkDateChange" value="{{formData.due_date}}">
              <view class="picker">
                {{formData.due_date || '请选择日期'}}
                <text class="picker-arrow">></text>
              </view>
            </picker>
          </view>

          <view class="form-item half">
            <text class="form-label">预计用时(分钟)</text>
            <input class="form-input" type="number" placeholder="请输入预计用时" value="{{formData.estimated_time}}" bindinput="onEstimatedTimeInput" catchtap="stopPropagation" maxlength="3" />
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">作业标题 *</text>
          <input class="form-input" placeholder="请输入作业标题" value="{{formData.title}}" bindinput="onTitleInput" catchtap="stopPropagation" maxlength="50" />
        </view>

        <view class="form-item">
          <text class="form-label">作业内容 *</text>
          <textarea class="form-textarea" placeholder="请详细描述作业内容" value="{{formData.description}}" bindinput="onDescriptionInput" catchtap="stopPropagation" maxlength="300" />
        </view>

        <view class="form-item">
          <text class="form-label">作业照片</text>
          <view class="image-upload">
            <view class="image-list">
              <view class="image-item" wx:for="{{formData.images}}" wx:key="timestamp">
                <image class="uploaded-img" src="{{item.url.startsWith('/') ? baseUrl + item.url : baseUrl + '/' + item.url}}" mode="aspectFill" bindtap="onImagePreview" data-url="{{item.url}}" data-source="form" catchtap="stopPropagation" />
                <view class="image-source-icon {{item.source}}">
                  <text wx:if="{{item.source === 'camera'}}">📷</text>
                  <text wx:if="{{item.source === 'album'}}">🖼️</text>
                </view>
                <view class="delete-btn" catchtap="onDeleteImage" data-index="{{index}}">×</view>
              </view>
              <view class="add-image" wx:if="{{formData.images.length < 9}}" bindtap="onChooseImage">
                <text class="add-icon">+</text>
                <text class="add-text">添加图片</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="modal-footer" catchtap="stopPropagation">
        <!-- 保存后继续添加选项 -->
        <view class="continue-add-option">
          <text class="continue-label" bindtap="onToggleContinueAdd">保存后继续添加</text>
          <checkbox class="continue-checkbox" checked="{{continueAddAfterSave}}" bindtap="onToggleContinueAdd" />
        </view>
        <view class="footer-buttons">
          <button class="cancel-btn" bindtap="onCancel">取消</button>
          <button class="save-btn" bindtap="onSave">保存</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 自定义时间选择器弹窗 -->
  <view class="modal-mask" wx:if="{{showCalendar}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">选择日期范围</text>
        <view class="close-btn" bindtap="onHideCalendar">×</view>
      </view>
      <calendar
        show="{{showCalendar}}"
        start-date="{{customStartDate}}"
        end-date="{{customEndDate}}"
        bind:cancel="onHideCalendar"
        bind:confirm="onCalendarConfirm">
      </calendar>
    </view>
  </view>
</view>