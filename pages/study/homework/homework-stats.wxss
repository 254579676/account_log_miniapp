.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header-info {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.child-info {
  display: flex;
  align-items: center;
}

.child-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.child-details {
  display: flex;
  flex-direction: column;
}

.child-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.page-title {
  font-size: 24rpx;
  color: #666;
}

.period-selector {
  flex-shrink: 0;
  width: auto;
  min-width: fit-content;
  white-space: nowrap;
  margin-top: 10rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  width: 90%;
  max-width: 650rpx;
  max-height: 80vh;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 40rpx 30rpx;
  border-bottom: 1rpx solid #f8f9fa;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.close-btn {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 10rpx;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 40rpx;
}

.date-range-row {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.date-picker-item {
  flex: 1;
}

.date-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.date-picker {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e8ecf1;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #333;
}

.date-separator {
  font-size: 28rpx;
  color: #666;
  padding-bottom: 20rpx;
  font-weight: 500;
}

.date-range-info {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
}

.range-text {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.range-warning {
  font-size: 24rpx;
  color: #ff5722;
  display: block;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 40rpx;
  border-top: 1rpx solid #f8f9fa;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.cancel-btn {
  background: #f8f9fa;
  color: #6c757d;
  border: 2rpx solid #e9ecef;
}

.confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.confirm-btn[disabled] {
  background: #ccc;
  color: #999;
}

/* 统计卡片 */
.stats-section {
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #2196F3;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 额外统计信息 */
.extra-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.extra-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.extra-stat-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.extra-stat-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

/* 图表部分 */
.chart-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #666;
}

.chart-container {
  height: 300rpx;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 250rpx;
  padding: 0 20rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  width: 40rpx;
  height: 200rpx;
  display: flex;
  align-items: flex-end;
  margin-bottom: 10rpx;
  position: relative;
}

.bar {
  width: 100%;
  border-radius: 4rpx 4rpx 0 0;
  position: absolute;
  bottom: 0;
}

.bar-completed {
  background: #4CAF50;
  z-index: 2;
}

.bar-total {
  background: #E0E0E0;
  z-index: 1;
}

.bar-label {
  font-size: 20rpx;
  color: #666;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 20rpx;
  height: 12rpx;
  border-radius: 2rpx;
}

.legend-color-completed {
  background: #4CAF50;
}

.legend-color-total {
  background: #E0E0E0;
}

.legend-text {
  font-size: 22rpx;
  color: #666;
}

/* 科目统计 */
.subject-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.subject-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.subject-item {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 25rpx;
  border-left: 4rpx solid #4CAF50;
}

.subject-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.subject-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  min-width: 100rpx;
  flex-shrink: 0;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #E0E0E0;
  border-radius: 6rpx;
  overflow: hidden;
  min-width: 150rpx;
}

.progress-fill {
  height: 100%;
  background: #4CAF50;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
  min-width: 80rpx;
  flex-shrink: 0;
  text-align: right;
}

.subject-time {
  text-align: right;
}

.time-text {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 0 20rpx;
}

.export-btn, .refresh-btn {
  flex: 1;
  background: white;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.export-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-color: #667eea;
}

.refresh-btn {
  background: linear-gradient(135deg, #27ae60 0%, #229954 100%);
  color: white;
  border-color: #27ae60;
}

.btn-icon {
  font-size: 24rpx;
}


.period-tabs {
  display: flex;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.period-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.period-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

/* 自定义时间范围 */
.custom-date-range {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 2rpx solid #e9ecef;
}

.date-range-row {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.date-picker-item {
  flex: 1;
}

.date-label {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.date-picker {
  width: 100%;
  height: 76rpx;
  border: 2rpx solid #e8ecf1;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #333;
}

.date-separator {
  font-size: 24rpx;
  color: #666;
  padding-bottom: 16rpx;
  font-weight: 500;
}

.date-range-info {
  background: white;
  padding: 16rpx;
  border-radius: 10rpx;
  border-left: 4rpx solid #667eea;
  margin-bottom: 20rpx;
}

.range-text {
  font-size: 24rpx;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.range-warning {
  font-size: 22rpx;
  color: #ff5722;
  display: block;
}

.query-btn {
  width: 100%;
  height: 76rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

.query-btn[disabled] {
  background: #ccc;
  color: #999;
  box-shadow: none;
}
