.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 顶部区域 */
.header-section {
  background: white;
  border-radius: 16rpx;
  padding: 15rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.student-selector {
  margin-bottom: 20rpx;
}

.current-student {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e9ecef;
  transition: all 0.2s ease;
}

.current-student:active {
  background: #e9ecef;
  transform: scale(0.98);
}

.student-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.student-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.student-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.student-grade {
  font-size: 24rpx;
  color: #666;
}

.selector-arrow {
  font-size: 24rpx;
  color: #999;
}

.grade-selector {
  margin-top: 10rpx;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e9ecef;
}

.picker-text {
  font-size: 24rpx;
  color: #333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 统计数据区域 */
.stats-section {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.stats-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e9ecef;
}

.stats-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.stats-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #2196F3;
}

/* 图表区域 */
.chart-section {
  background: white;
  border-radius: 16rpx;
  padding: 15rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.chart-controls {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.control-btn {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.control-btn.active {
  color: white;
  background: #2196F3;
}

.subject-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  min-width: 80rpx;
}

.chart-container {
  position: relative;
  margin-top: 20rpx;
  width: 100%;
  max-width: 700rpx; /* 限制最大宽度，约等于350px */
  margin-left: auto;
  margin-right: auto;
}

.chart-canvas {
  width: 100%;
  height: 350rpx;
  border: 1rpx solid #f0f0f0;
  border-radius: 8rpx;
  z-index: 1;
}

.chart-legend {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.legend-dot.comprehensive {
  background: #2196F3;
}

.legend-dot.subject {
  background: #4CAF50;
}

.legend-text {
  font-size: 24rpx;
  color: #666;
}



/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 600rpx;
  border-radius: 16rpx;
  max-height: 80vh;
  background: white;
  overflow: hidden;
}

/* 隐藏类 */
.hidden {
  display: none !important;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.student-list {
  max-height: 60vh;
  overflow-y: auto;
}

.student-option {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.student-option:active {
  background: #f8f9fa;
}

.student-option.active {
  background: rgba(33, 150, 243, 0.1);
}

.option-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.option-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.option-grade {
  font-size: 24rpx;
  color: #666;
}

.option-check {
  width: 40rpx;
  height: 40rpx;
  background: #2196F3;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* tooltip样式 */
.tooltip {
  position: absolute;
  pointer-events: none;
  transform: translateX(-50%);
}

.tooltip-content {
  background: rgba(0, 0, 0, 0.8);
  color: white;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
  min-width: 120rpx;
  text-align: center;
}

.tooltip-type {
  display: block;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.tooltip-score {
  display: block;
  font-size: 28rpx;
  color: #4CAF50;
  margin-bottom: 4rpx;
}

.tooltip-date {
  display: block;
  font-size: 20rpx;
  opacity: 0.8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}