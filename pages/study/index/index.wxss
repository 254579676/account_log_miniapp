/* 页面容器 */
.container {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
  padding: 20rpx;
}

/* 通用卡片样式 */
.student-selector-card,
.overview-card,
.function-card,
.activity-card,
.no-child-card {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.card-date {
  font-size: 24rpx;
  color: #7f8c8d;
}

/* 添加按钮 */
.add-btn {
  background: linear-gradient(135deg, #8dc7ee, #32c557);
  color: white;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.add-btn:active {
  transform: scale(0.9);
  background: linear-gradient(135deg, #2980b9, #21618c);
}

/* 学生选择器 */
.student-selector-card {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.student-content {
  display: flex;
  align-items: center;
  flex: 1;
  padding: 8rpx 0;
  transition: all 0.3s ease;
}

.student-content:active {
  transform: scale(0.98);
}

.student-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 2rpx solid #ecf0f1;
  flex-shrink: 0;
}

.student-name {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  background: linear-gradient(135deg, #3498db, #2980b9);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.student-grade {
  font-size: 24rpx;
  color: #34495e;
  background: #89eb8e;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.student-school {
  font-size: 24rpx;
  text-align: center;
  color: #34495e;
  background: #e1e281;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.switch-icon {
  font-size: 20rpx;
  color: #3498db;
  margin-right: 40rpx;
  flex-shrink: 0;
}

.student-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.current-student-info {
  flex: 1;
}

.info-label {
  font-size: 20rpx;
  color: #7f8c8d;
  display: block;
  margin-bottom: 4rpx;
}

.info-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 4rpx;
}

.info-school {
  font-size: 22rpx;
  color: #f8fafa;
  display: block;
}

/* 学生选择弹窗 */
.student-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.picker-content {
  background: white;
  border-radius: 20rpx;
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #f8f9fa;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.close-btn {
  font-size: 40rpx;
  color: #7f8c8d;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: white;
  border: 1rpx solid #ecf0f1;
  transition: all 0.3s ease;
}

.close-btn:active {
  background: #f8f9fa;
  transform: scale(0.9);
}

.picker-scroll {
  max-height: 60vh;
}

.picker-list {
  padding: 20rpx 0;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  transition: all 0.3s ease;
  position: relative;
}

.picker-item:active {
  background: #f8f9fa;
}

.picker-item.active {
  background: #e3f2fd;
}

.picker-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #ecf0f1;
}

.picker-item.active .picker-avatar {
  border-color: #3498db;
}

.picker-info {
  flex: 1;
  min-width: 0;
}

.picker-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 6rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-item.active .picker-name {
  color: #3498db;
}

.picker-details {
  font-size: 22rpx;
  color: #7f8c8d;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-check {
  font-size: 32rpx;
  color: #3498db;
  font-weight: bold;
  margin-left: 20rpx;
}

/* 无学生提示 */
.no-child-card {
  text-align: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #2c3e50;
  display: block;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 22rpx;
  color: #7f8c8d;
  display: block;
  margin-bottom: 30rpx;
}

.add-first-btn {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 20rpx 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 今日学习概览 */
.overview-card {
  padding: 0;
}

/* 每日鼓励诗词 */
.daily-quote {
  background: linear-gradient(135deg, #d4edda 0%, #34d65a 100%);
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  white-space: nowrap;
  overflow: hidden;
  position: relative;
}

.quote-text {
  font-size: 30 rpx;
  color: #100d9c;
  font-weight: 500;
  line-height: 1.4;
  letter-spacing: 2rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  white-space: nowrap;
  animation: scrollText 10s linear infinite;
  padding-left: 100%;
}

@keyframes scrollText {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-100%);
  }
}

/* 自适应字体大小 */
@media (max-width: 750rpx) {
  .quote-text {
    font-size: 26rpx;
    letter-spacing: 3rpx;
  }
}

@media (max-width: 600rpx) {
  .quote-text {
    font-size: 24rpx;
    letter-spacing: 2rpx;
  }
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
}

.overview-item {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-right: 1rpx solid #f0f0f0;
}

.overview-item:last-child {
  border-right: none;
}

.overview-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 30rpx;
}


.exam-icon {
  background: #e3f2fd;
  color: #2196f3;
}

.time-icon {
  background: #e8f5e8;
  color: #4caf50;
}

.overview-data {
  flex: 1;
}

.overview-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 4rpx;
}

.overview-label {
  font-size: 20rpx;
  color: #7f8c8d;
}

/* 功能入口 */
.function-card {
  padding: 0;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
  padding: 20rpx;
}

.function-item {
  text-align: center;
  padding: 30rpx 20rpx;
  border-right: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.function-item:nth-child(2n) {
  border-right: none;
}

.function-item:nth-last-child(-n+2) {
  border-bottom: none;
}

.function-item:active {
  background: #f8f9fa;
  transform: scale(0.95);
}

.function-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  font-size: 32rpx;
}

.homework-bg {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
}

.exam-bg {
  background: linear-gradient(135deg, #4ecdc4, #88d8c0);
}

.error-bg {
  background: linear-gradient(135deg, #feca57, #ff9ff3);
}

.score-bg {
  background: linear-gradient(135deg, #48dbfb, #0abde3);
}

.function-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 8rpx;
}

.function-desc {
  font-size: 20rpx;
  color: #7f8c8d;
  line-height: 1.4;
}

/* 最近活动 */
.activity-card {
  padding: 0;
}

.activity-list {
  padding: 0 30rpx 30rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-item:active {
  background: #f8f9fa;
}

.activity-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 22rpx;
}

.homework-icon {
  background: #fff3e0;
  color: #ff9800;
}

.exam-icon {
  background: #e3f2fd;
  color: #2196f3;
}

.error-icon {
  background: #ffebee;
  color: #f44336;
}

.activity-content {
  flex: 1;
}

.activity-title {
  font-size: 26rpx;
  color: #2c3e50;
  display: block;
  margin-bottom: 4rpx;
}

.activity-desc {
  font-size: 20rpx;
  color: #7f8c8d;
}

.activity-time {
  font-size: 20rpx;
  color: #bdc3c7;
}

/* 考试列表样式 */
.exam-list {
  padding: 0 30rpx 30rpx;
}

.exam-item {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 10rpx;
  padding: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.exam-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.12);
}

.exam-main-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.exam-left {
  flex: 1;
  min-width: 0;
}

.exam-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8rpx;
  display: block;
}

.exam-subject {
  font-size: 24rpx;
  color: #7f8c8d;
  background: #f8f9fa;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.exam-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.score {
  font-size: 32rpx;
  font-weight: 700;
  color: #4CAF50;
}

.total-score {
  font-size: 24rpx;
  color: #95a5a6;
}

.exam-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date {
  font-size: 24rpx;
  color: #95a5a6;
}

.footer-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.image-icon {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #3498db;
  padding: 6rpx 12rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
}

.icon-text {
  font-size: 20rpx;
}

.icon-count {
  font-size: 20rpx;
  color: #3498db;
}

.ranking {
  font-size: 22rpx;
  color: #e74c3c;
  background: #ffebee;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #2c3e50;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 22rpx;
  color: #7f8c8d;
  display: block;
}