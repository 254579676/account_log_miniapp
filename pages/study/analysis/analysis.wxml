<view class="analysis-container">
  <!-- 顶部学生信息展示 -->
  <view class="header-section">
    <view class="student-selector">
      <view class="current-student" bindtap="onShowStudentPicker">
        <image class="student-avatar" src="{{currentChild.avatar_url || '/assets/icons/child.png'}}" />
        <view class="student-info">
          <text class="student-name">{{currentChild.name}}</text>
          <text class="student-grade">{{currentChild.grade || ''}} {{currentChild.class || ''}}-{{currentChild.school || ''}}</text>
        </view>
        <text class="selector-arrow">▼</text>
      </view>
    </view>
  </view>

  <!-- 学科错题统计 -->
  <view class="subject-stats">
    <view class="stats-header">
      <view class="stats-title">学科错题统计</view>
      <!-- 年级选择器 -->
      <view class="grade-selector-inline">
        <picker mode="selector" range="{{gradeOptions}}" range-key="name" value="{{selectedGradeIndex}}" bindchange="onGradeChangeForStats">
          <view class="picker-inline">
            <text class="picker-text">{{selectedGrade.name || '选择年级'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="chart-container">
      <view class="chart-bars">
        <view class="bar-item" wx:for="{{subjectStats}}" wx:key="name">
          <view class="bar-wrapper">
            <view class="bar-value">{{item.count}}</view>
            <view class="bar" style="height: {{item.maxHeight}}rpx;">
              <view class="bar-fill" style="height: {{item.barHeight}}rpx; background: {{item.color}};"></view>
            </view>
          </view>
          <view class="bar-label">{{item.name}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 科目分析 -->
  <view class="analysis-section">
    <view class="section-header">
      <view class="section-title">科目分析</view>
      <view class="subject-picker-container">
        <picker mode="selector" range="{{subjectOptions}}" range-key="name" value="{{selectedSubjectIndex}}" bindchange="onSubjectChangeForAnalysis">
          <view class="subject-picker">
            <text class="subject-picker-text">{{selectedAnalysisSubject.name || '语文'}}</text>
            <text class="subject-picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 题型分析 -->
    <view class="analysis-subsection">
      <view class="subsection-title">题型分析</view>
      <view class="chart-container">
        <view class="chart-row" wx:for="{{questionTypeAnalysis}}" wx:key="id">
          <view class="chart-bar" style="width: {{item.percentage}}%; background-color: {{item.color}};">
            <text class="chart-count">{{item.count}}</text>
          </view>
          <view class="chart-info">
            <view class="chart-label">{{item.label}}</view>
            <view class="chart-tips-icon" wx:if="{{item.description}}" bindtap="onShowDescription" data-description="{{item.description}}">❓</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 错题原因分析 -->
    <view class="analysis-subsection">
      <view class="subsection-title">错题原因分析</view>
      <view class="reason-container">
        <view class="reason-item" wx:for="{{reasonAnalysis}}" wx:key="id">
          <view class="reason-bar" style="width: {{item.percentage}}%; background-color: {{item.color}};">
            <text class="reason-count">{{item.count}}</text>
          </view>
          <view class="reason-info">
            <view class="reason-label">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 趋势分析 -->
  <view class="trend-section">
    <view class="section-title">错题趋势</view>
    <bar-chart
      chartId="trendChart"
      chartData="{{trendChartData}}"
      chartTitle="错题趋势"
      barColor="#1890ff"
      enableTouch="true">
    </bar-chart>
  </view>

  <!-- 学生选择弹窗 -->
  <view class="modal-mask" wx:if="{{showStudentPicker}}" bindtap="onHideStudentPicker">
    <view class="modal-content" catchtap="onModalContentTap">
      <view class="modal-header">
        <text class="modal-title">选择学生</text>
        <text class="close-btn" bindtap="onHideStudentPicker">×</text>
      </view>
      <view class="student-list">
        <view class="student-option {{item.id === currentChild.id ? 'active' : ''}}"
              wx:for="{{childrenList}}" wx:key="id"
              bindtap="onSelectStudent" data-student="{{item}}">
          <image class="option-avatar" src="{{item.avatar_url || '/assets/icons/child.png'}}" />
          <view class="option-info">
            <text class="option-name">{{item.name}}</text>
            <text class="option-grade">{{item.grade || ''}} {{item.class || ''}}-{{item.school || ''}}</text>
          </view>
          <view class="option-check" wx:if="{{item.id === currentChild.id}}">✓</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{isLoading}}" class="loading-overlay">
    <view class="loading-spinner"></view>
    <text>分析中...</text>
  </view>
</view>
