.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.form-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  margin-bottom: 0;
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
  font-weight: normal;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  border: 2rpx solid #e0e0e0;
}

.avatar-tip {
  font-size: 22rpx;
  color: #999;
}

.form-input {
  width: 100%;
  height: 70rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.picker {
  width: 100%;
  height: 70rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #333;
  box-sizing: border-box;
}

.picker-arrow {
  color: #999;
  font-size: 24rpx;
}

.action-section {
  padding: 0 20rpx;
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 20rpx;
  margin-bottom: 40rpx;
}

.primary-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 80rpx;
  box-sizing: border-box;
}

.primary-btn::after {
  border: none;
}

.primary-btn:disabled {
  opacity: 0.6;
  background: #ccc;
}

.secondary-btn {
  flex: 1;
  height: 80rpx;
  background: #ff4757;
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 80rpx;
  box-sizing: border-box;
}

.secondary-btn::after {
  border: none;
}

.secondary-btn:disabled {
  opacity: 0.6;
  background: #ccc;
}

.cancel-btn {
  flex: 1;
  height: 80rpx;
  background: #ffffff;
  color: #666666;
  border: 1rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 80rpx;
  box-sizing: border-box;
}

.cancel-btn::after {
  border: none;
}