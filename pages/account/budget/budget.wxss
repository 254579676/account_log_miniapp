
/* 预算页面样式 */
.time-selector {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx 16rpx 0 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.picker {
  margin: 0 24rpx;
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.3s;
}

.picker:active {
  background-color: #e0e0e0;
}

.tabs {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 0 0 16rpx 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab {
  width: 25%;
  padding: 24rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s;
}

.tab.active {
  color: #fff;
  font-weight: 500;
  background-color: #4fad56;
}

.tab-icon {
  width: 60rpx;
  height: 60rpx;
  display: block;
  margin: 0 auto 12rpx;
}

.budget-list {
  margin: 20rpx 0;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
}

.list-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.item-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.item-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.item-budget {
  font-size: 28rpx;
  color: #ff6b6b;
}

.budget-form {
  position: fixed;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx 16rpx 0 0;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 9; /* 确保按钮在表单上方 */
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #eee;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  flex: 1;
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #333;
}

.label-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

input {
  width: 200rpx;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 24rpx;
  text-align: right;
  font-size: 32rpx;
  color: #333;
}

.unit {
  margin-left: 16rpx;
  color: #666;
}

.form-save-btn {
  background: linear-gradient(135deg, #4CAF50, #2E7D32) !important;
  color: #fff !important;
  border-radius: 8rpx !important;
  font-size: 28rpx !important;
  font-weight: 500 !important;
  height: 60rpx !important;
  width: 120rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
  box-sizing: border-box !important;
  margin-left: 10px !important;
}

/* 滑动删除样式 */
.movable-area {
  width: 100%;
  height: 100rpx;
  margin-bottom: 10rpx;
}

.movable-view {
  width: calc(100% + 160rpx);
  height: 100%;
  display: flex;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f5f5f5;
  width: 100%;
}

.delete-btn {
  width: 160rpx;
  height: 100%;
  background-color: #ff4d4f;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}