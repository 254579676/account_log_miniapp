/* pages/detail/detail.wxss */
/* 筛选栏 */
.filter-bar {
  display: flex;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 28rpx 0;
  font-size: 34rpx;
  color: #757575;
  font-weight: 500;
}

.filter-item text {
  margin-right: 12rpx;
}

.filter-item:active {
  opacity: 0.8;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  padding: 40rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-label {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.stats-value {
  font-size: 36rpx;
  font-weight: 500;
}

.stats-value.text-danger {
  color: #FFEB3B;
}

.stats-value.text-primary {
  color: #E8F5E9;
}

.stats-divider {
  width: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
  margin: 0 20rpx;
}

/* 账单列表 */
.bill-list {
  margin-top: 20rpx;
}

.date-group {
  margin-bottom: 20rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx 12rpx 0 0;
}

.date-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.date-summary {
  font-size: 24rpx;
  color: #666;
}

.bill-items {
  background-color: #fff;
  border-radius: 0 0 12rpx 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.bill-item {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.bill-item:last-child {
  border-bottom: none;
}

.bill-category {
  margin-right: 20rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #f8f9fa;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.bill-info {
  flex: 1;
}

.bill-title {
  font-size: 28rpx;
  margin-bottom: 6rpx;
  font-weight: 500;
  color: #333;
}

.bill-desc {
  font-size: 24rpx;
  color: #999;
}

.bill-amount {
  font-size: 32rpx;
  font-weight: 500;
}

/* 无数据提示 */
.no-data {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.no-data image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

.no-data-text {
  font-size: 30rpx;
  color: #9E9E9E;
}

/* 加载更多 */
.load-more-container {
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
}

.load-more-btn {
  background-color: #f5f5f5;
  color: #333;
  border: none;
  border-radius: 40rpx;
  padding: 0 40rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.load-more-btn:active {
  background-color: #e8e8e8;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
  text-align: center;
  padding: 20rpx 0;
}

/* 筛选弹窗 */
.filter-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.filter-popup.show {
  visibility: visible;
  opacity: 1;
}

.filter-popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.filter-popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.filter-popup.show .filter-popup-content {
  transform: translateY(0);
}

.filter-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-popup-header text {
  font-size: 32rpx;
  font-weight: 500;
}

.filter-popup-body {
  max-height: 60vh;
  overflow-y: auto;
  padding: 20rpx 30rpx;
}

.filter-option {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #f5f5f5;
  font-weight: 500;
}

.filter-option.active {
  color: #4CAF50;
}

.filter-option-icon {
  margin-right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.filter-group-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 0 10rpx;
  font-weight: 500;
}

.filter-popup-footer {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
}

.filter-popup-footer .btn {
  flex: 1;
  margin: 0 10rpx;
}

/* 自定义日期范围 */
.custom-date-range {
  background-color: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.date-picker:last-child {
  border-bottom: none;
}

.picker-value {
  display: flex;
  align-items: center;
}

.picker-value text {
  margin-right: 10rpx;
}
/* 新增滚动容器样式 */
.bill-items-scroll {
  width: 100%;
  box-sizing: border-box;
  margin-top: 10rpx;
  border-radius: 16rpx;
  background-color: #f8f8f8;
}