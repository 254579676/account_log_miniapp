/* pages/detail/transaction-detail.wxss */
.detail-card {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.amount-section {
  padding: 40rpx;
  text-align: center;
}

.amount-section.expense {
  background: linear-gradient(135deg, #F44336, #D32F2F);
}

.amount-section.income {
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
}

.amount-label {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.amount-value {
  font-size: 60rpx;
  font-weight: 500;
  color: #fff;
}

.detail-list {
  padding: 0 30rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.detail-value {
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #333;
  font-weight: 500;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #f8f9fa;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.action-buttons {
  display: flex;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: transparent;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.action-btn::after {
  border: none;
}

.edit-btn {
  border-right: 1rpx solid #eee;
}

.delete-btn {
  color: #F44336;
}

/* 编辑弹窗 */
.edit-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.edit-popup.show {
  visibility: visible;
  opacity: 1;
}

.edit-popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.edit-popup-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 80%;
  background-color: #fff;
  border-radius: 12rpx;
  transition: transform 0.3s;
}

.edit-popup.show .edit-popup-content {
  transform: translate(-50%, -50%) scale(1);
}

.edit-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.edit-popup-header text {
  font-size: 32rpx;
  font-weight: 500;
}

.edit-popup-close {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.edit-popup-body {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 类型选择器 */
.type-selector {
  display: flex;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  overflow: hidden;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.type-option.active {
  background-color: #4CAF50;
  color: #fff;
}

.edit-popup-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
}

.edit-popup-footer .btn {
  flex: 1;
  margin: 0 10rpx;
}

/* 删除确认弹窗 */
.confirm-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.confirm-popup.show {
  visibility: visible;
  opacity: 1;
}

.confirm-popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.confirm-popup-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 80%;
  background-color: #fff;
  border-radius: 12rpx;
  transition: transform 0.3s;
  padding: 40rpx;
  text-align: center;
}

.confirm-popup.show .confirm-popup-content {
  transform: translate(-50%, -50%) scale(1);
}

.confirm-popup-title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.confirm-popup-message {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.confirm-popup-buttons {
  display: flex;
}

.confirm-popup-buttons .btn {
  flex: 1;
  margin: 0 10rpx;
}