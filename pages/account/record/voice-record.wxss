/* pages/record/voice-record.wxss */
.container {
  padding: 0;
}

.voice-area {
  width: 100%;
  height: 500rpx;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  padding: 60rpx 0;
}

.voice-status {
  width: 100%;
  text-align: center;
  color: #fff;
}

.start-tips {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tips-text {
  font-size: 32rpx;
  margin-top: 30rpx;
}

.tips-example {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 10rpx;
}

.recording-animation {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 30rpx;
}

.wave {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  left: 0;
  top: 0;
  animation: wave 2s infinite;
}

.wave1 {
  animation-delay: 0s;
}

.wave2 {
  animation-delay: 0.5s;
}

.wave3 {
  animation-delay: 1s;
}

@keyframes wave {
  0% {
    transform: scale(0.5);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.recording-text {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

/* 实时识别结果样式 */
.realtime-result {
  background-color: rgba(255, 255, 255, 0.15);
  padding: 20rpx 30rpx;
  border-radius: 8rpx;
  margin: 20rpx 40rpx;
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.realtime-text {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.4;
  text-align: center;
}

.recording-tips {
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.recording-example {
  font-size: 24rpx;
  opacity: 0.8;
}

.recognition-text {
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.voice-content {
  font-size: 28rpx;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 20rpx;
  border-radius: 8rpx;
  max-width: 80%;
  margin: 0 auto;
}

.voice-action {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.record-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
}

.record-btn.recording {
  background-color: #F44336;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
  }
}

.action-text {
  color: #fff;
  font-size: 28rpx;
}

/* 识别结果表单区域样式 */
.recognition-result {
  padding: 30rpx;
}

.result-header {
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.result-tips {
  font-size: 24rpx;
  color: #999;
}

.form-section {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #333;
}

.form-value {
  color: #666;
}

.form-value input {
  text-align: right;
  width: 400rpx;
}

.picker-value {
  display: flex;
  align-items: center;
}

.picker-value text {
  margin-right: 10rpx;
}

.save-btn-container {
  padding: 20rpx 0;
}

.save-btn {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 8rpx;
  font-size: 32rpx;
}