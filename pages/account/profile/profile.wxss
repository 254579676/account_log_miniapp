/* pages/profile/profile.wxss */
.container {
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  position: relative;
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  color: #fff;
  /* box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05); */
}

.user-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  overflow: hidden;
  background-color: #fff;
  margin-right: 30rpx;
  border-radius: 50%; /* 圆形头像 */
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar-image {
  width: 100%;
  height: 100%;
  border: 2rpx solid #eee; /* 可选：添加边框 */
  z-index: 1; /* 确保头像显示在皇冠下方 */
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.user-id {
  font-size: 26rpx;
  opacity: 0.9;
}
.login-btn {
  background: rgba(255, 255, 255, 0);
  color: white;
  border-radius: 30rpx;
  padding: 15rpx 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  width: 200rpx !important;
}

.login-btn::after {
  border: none;
}

/* 已登录用户信息 */
.user-logged-in-section {
  background-color: transparent;
  padding: 0;
  border-radius: 16rpx;
  margin-bottom: 0;
  box-shadow: none;
  text-align: right;
}

.logged-in-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.welcome-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 12rpx;
  text-align: right;
}

.logout-btn {
  background: rgba(255, 255, 255, 0.2);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 50rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  top: 36rpx;
  width: 200rpx !important;
}

.logout-btn::after {
  border: none;
}

/* 账户概览 */
.account-overview {
  display: flex;
  background-color: #fff;
  padding: 40rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #4CAF50;
  margin-bottom: 12rpx;
}

.overview-label {
  font-size: 28rpx;
  color: #9E9E9E;
  font-weight: 500;
}

/* 功能列表 */
.feature-list {
  margin-bottom: 24rpx;
}

.feature-group {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-item:active {
  background-color: #f8f9fa;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFFFFF, #F5F5F5);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.feature-info {
  flex: 1;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #212121;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #9E9E9E;
}

.feature-arrow {
  margin-left: 24rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  font-size: 26rpx;
  color: #9E9E9E;
  padding: 36rpx 0;
}

.icon {
  width: 48rpx;
  height: 48rpx;
  vertical-align: middle;
}

/* 会员图标（皇冠）：绝对定位到右上角 */
.crown-icon {
  position: absolute; /* 绝对定位，相对于父容器 */
  top: -10rpx; /* 向上偏移，部分超出头像容器顶部 */
  right: 40rpx; /* 向右偏移，部分超出头像容器右侧 */
  width: 40rpx; /* 皇冠图标宽度 */
  height: 40rpx; /* 皇冠图标高度 */
  z-index: 2; /* 确保皇冠显示在头像上方 */
}

/* 登录/注册弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 100;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #212121;
}

.close-btn {
  width: 40rpx;
  height: 40rpx;
}

.close-icon {
  width: 100%;
  height: 100%;
}

.modal-body {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.remember-me {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.remember-me-label {
  display: flex;
  align-items: center;
}

.remember-me-text {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #666;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  border-top: 2rpx solid #f5f5f5;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
  margin-right: 20rpx;
  border: none;
}

.cancel-btn::after {
  border: none;
}

.confirm-btn {
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  color: white;
  border: none;
  margin-left: 20rpx;
}

.confirm-btn::after {
  border: none;
}

.switch-mode {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #9E9E9E;
}

.switch-text {
  color: #4CAF50;
  margin-left: 10rpx;
  font-weight: 500;
}