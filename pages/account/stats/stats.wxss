/* pages/stats/stats.wxss */

.container {
  padding-bottom: 40rpx;
}

/* 日期筛选器 */
.date-filter {
  display: flex;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.filter-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 34rpx;
  color: #757575;
  position: relative;
  font-weight: 500;
  transition: all 0.3s ease;
}

.filter-btn:active {
  opacity: 0.8;
}

.filter-btn.active {
  color: #4CAF50;
  font-weight: 600;
}

.filter-btn.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #4CAF50, #81C784);
  border-radius: 3rpx;
}

/* 自定义日期选择器 */
.custom-date-picker {
  background-color: #fff;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.date-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx;
  border-bottom: 2rpx solid #eee;
}

.close-btn {
  padding: 10rpx;
}

.date-picker-body {
  padding: 30rpx 36rpx;
}

.date-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #eee;
}

.date-item:last-child {
  border-bottom: none;
}

.date-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #212121;
}

.date-value text {
  margin-right: 12rpx;
}

.date-picker-footer {
  padding: 30rpx 36rpx;
  border-top: 2rpx solid #eee;
}

.btn-confirm {
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  height: 80rpx;
  line-height: 50rpx;
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.3);
}

.btn-confirm:active {
  transform: scale(0.98);
}

/* 统计概览 */
.stats-overview {
  display: flex;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  padding: 40rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.overview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-label {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 500;
}

.overview-value.expense {
  color: #FFF176;
}

.overview-value.income {
  color: #E8F5E9;
}

/* 类型切换 */
.type-tabs {
  display: flex;
  background-color: #fff;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 36rpx;
  color: #757575;
  position: relative;
  font-weight: 500;
  transition: all 0.3s ease;
}

.tab:active {
  opacity: 0.8;
}

.tab.active {
  color: #4CAF50;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #4CAF50, #81C784);
  border-radius: 3rpx;
}

/* 图表区域 */
.chart-container {
  background-color: #fff;
  padding: 36rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.chart-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 36rpx;
  color: #212121;
}

#pie-chart, #bar-chart {
  width: 100%;
  height: 400rpx;
}

.chart-placeholder {
  height: 400rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 16rpx;
}

.chart-note {
  font-size: 28rpx;
  color: #9E9E9E;
  margin-top: 12rpx;
}

/* 分类明细 */
.category-list {
  background-color: #fff;
  padding: 36rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.list-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 36rpx;
  color: #212121;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid #f5f5f5;
}

.category-item:last-child {
  border-bottom: none;
}

.category-info {
  display: flex;
  align-items: center;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFFFFF, #F5F5F5);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.category-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #212121;
}

.category-stats {
  text-align: right;
}

.category-amount {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #212121;
}

.category-percent {
  font-size: 26rpx;
  color: #9E9E9E;
}

/* 无数据提示 */
.no-data {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #9E9E9E;
}

.no-data image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

.no-data text {
  margin-top: 24rpx;
  font-size: 30rpx;
}

.icon {
  width: 48rpx;
  height: 48rpx;
  vertical-align: middle;
}